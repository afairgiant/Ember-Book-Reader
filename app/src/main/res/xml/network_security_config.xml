<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Cleartext HTTP is permitted globally because Ember's primary use case
        involves connecting to self-hosted Grimmory servers on local networks
        via IP addresses (e.g. http://192.168.1.50:6060). Android's network
        security config does not support IP subnet/CIDR matching, so we cannot
        restrict cleartext to private IP ranges only.

        Security considerations:
        - The app only connects to servers the user explicitly configures
        - HTTPS connections are preferred and work without any special config
        - Local network traffic has lower MITM risk than public internet
        - Credentials are stored encrypted via EncryptedSharedPreferences
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
