<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Permit cleartext HTTP so users can reach self-hosted servers
        (e.g. Grimmory) on local/private network IPs.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
